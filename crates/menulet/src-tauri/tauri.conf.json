{
  "$schema": "https://raw.githubusercontent.com/nicedoc/tauri/HEAD/crates/tauri-config-schema/schema.json",
  "productName": "Indiana",
  "version": "0.2.0",
  "identifier": "com.indiana.menulet",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run ui:dev",
    "beforeBuildCommand": "npm run ui:build"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "Indiana",
        "width": 300,
        "height": 240,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/indiana"
    ]
  }
}
