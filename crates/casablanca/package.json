{
  "name": "casablanca",
  "version": "0.1.0",
  "private": true,
  "description": "Casablanca — a minimal Electron note editor with a WYSIWYG Lexical editor and inline Excalidraw diagrams.",
  "type": "module",
  "author": "Casablanca",
  "license": "MIT",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "dist": "electron-vite build && electron-builder",
    "dist:dir": "electron-vite build && electron-builder --dir",
    "preview": "electron-vite preview",
    "start": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@excalidraw/excalidraw": "^0.17.6",
    "@lexical/code": "^0.22.0",
    "@lexical/link": "^0.22.0",
    "@lexical/list": "^0.22.0",
    "@lexical/markdown": "^0.22.0",
    "@lexical/react": "^0.22.0",
    "@lexical/rich-text": "^0.22.0",
    "@lexical/selection": "^0.22.0",
    "@lexical/utils": "^0.22.0",
    "chokidar": "^4.0.1",
    "lexical": "^0.22.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@lexical/headless": "^0.22.0",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "electron": "^33.0.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^2.3.0",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vitest": "^4.1.9"
  },
  "build": {
    "appId": "com.niklas.casablanca",
    "productName": "Casablanca",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "mac": {
      "target": [
        { "target": "dmg", "arch": ["arm64"] }
      ],
      "identity": null,
      "category": "public.app-category.productivity"
    },
    "dmg": {
      "artifactName": "Casablanca_${version}_aarch64.dmg"
    }
  }
}
