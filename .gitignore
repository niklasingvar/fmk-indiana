# Rust build output
/target
**/target/

# Node / frontend build output
**/node_modules/
**/dist/
# Homebrew cask/formula source-of-truth live under the gitignored dist/ root,
# so re-include that one subtree. Build outputs (crates/*/dist/) stay ignored.
!/dist/

# Local scratch fixtures
/tmp
tmp_*

# macOS
.DS_Store
.cursor/
indiana-aarch64-apple-darwin.tar.gz

# Menulet Tauri sidecar (copied from target/release by make sidecar-copy)
crates/menulet/src-tauri/binaries/indiana-*

# Tauri-generated schemas (regenerated each build)
crates/menulet/src-tauri/gen/

# Legacy paths (pre-crates/ layout)
MENULET/src-tauri/target/
MENULET/src-tauri/binaries/indiana-*
MENULET/src-tauri/gen/
MENULET/node_modules/
MENULET/dist/

# Local Nimbalyst reference checkout (Casablanca UI inspiration)
crates/casablanca/nimbalyst/
